{
  "name": "creavid-vev",
  "version": "0.1.0",
  "description": "VEV — webpage → NDI. Render any page offscreen at broadcast resolution and publish it as a real NDI source (video + alpha), navigable through a live preview.",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "koffi": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.9.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.2.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "zod": "^3.23.0"
  }
}
