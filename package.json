{
  "name": "pane",
  "version": "0.1.1",
  "description": "Pane — webpage → NDI. Render any page offscreen at broadcast resolution and publish it as a real NDI source (video + alpha), navigable through a live preview.",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --win --publish never",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "build": {
    "appId": "no.creavid.pane",
    "productName": "Pane",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/koffi/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "nacalai",
      "repo": "pane"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Pane"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "koffi": "^3.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}
